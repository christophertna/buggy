# MySQL 9.2 connection
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=agent_user
MYSQL_PASSWORD=your_real_mysql_password
MYSQL_DATABASE=app_db
MYSQL_CONNECT_TIMEOUT=5

# Harness tuning (see CONSTITUTION.md before changing these)
MAX_ROWS_AFFECTED=500
PROTECTED_TABLES=users,payments,audit_log

# OpenAI
OPENAI_API_KEY=sk-your-real-key
OPENAI_MODEL=gpt-4.1
OPENAI_TEMPERATURE=0.1

# Loop paths
TASKS_FILE=tasks.json
HISTORY_LOG=history.log

# Supabase (Postgres): read-only source of client profile data
SUPABASE_URL=https://your-supabase-project.supabase.co/
SUPABASE_KEY=sb_publishable_your_real_key

# Document Automation module
DOC_TEMPLATE_ATTRIBUTE=state
CLIENTS_INPUT_FILE=clients.txt
DOCUMENT_OUTPUT_DIR=output/documents
FIELD_MAP_PATH=config/field_map.json
PDF_TEMPLATE_ROOT=templates/pdf
